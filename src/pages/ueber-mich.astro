---
import Layout from '~/layouts/PageLayout.astro';
import { getEntry } from 'astro:content';
import { render } from 'astro:content';
import Image from '~/components/common/Image.astro';
import innsbruckImg from '~/assets/images/innsbruck.jpg';
import profileImg from '~/assets/images/profile_picture_transparent.png';

const entry = await getEntry('pages', 'ueber-mich');

if (!entry) {
  throw new Error('Could not find ueber-mich page');
}

const { Content } = await render(entry);
const { title } = entry.data;

const metadata = {
  title: title,
};
---

<Layout metadata={metadata}>
  <section class="px-4 py-16 sm:px-6 mx-auto lg:px-8 lg:py-20 max-w-4xl">
    <div class="flex items-center gap-6 mb-8">
      <Image
        src={profileImg}
        alt="Matthias Andrasch"
        class="w-[120px] h-[120px] rounded-full object-cover border-[3px] border-[var(--border)] bg-[var(--bg-secondary)] shrink-0"
        width={120}
        height={120}
      />
      <h1 class="text-4xl md:text-5xl font-bold leading-tighter tracking-normal font-heading">
        {title}
      </h1>
    </div>
    <div class="mx-auto prose dark:prose-invert max-w-4xl">
      <Content />
      
      <div class="mt-12">
        <Image
          src={innsbruckImg}
          alt="Innsbruck"
          class="w-full h-auto rounded-lg shadow-lg"
          width={1920}
          height={1080}
        />
      </div>
    </div>
  </section>
</Layout>
